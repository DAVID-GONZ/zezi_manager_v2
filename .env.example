# =============================================================================
# .env.example — Plantilla de configuración de ZECI Manager v2.0
# =============================================================================
# Copia este archivo a `.env` y ajusta los valores para tu entorno.
# NUNCA pongas secretos reales en este archivo de ejemplo ni lo subas a git.
# Las variables aquí declaradas se leen en config.py (Settings).
# -----------------------------------------------------------------------------

# Entorno de ejecución: development | production | test
# En production, los secretos de abajo DEBEN definirse explícitamente.
APP_ENV=development

# Ruta al archivo SQLite (relativa a la raíz del proyecto o absoluta).
DATABASE_PATH=data/app.db

# -----------------------------------------------------------------------------
# Secretos (seguridad)
# -----------------------------------------------------------------------------
# JWT_SECRET     → firma los tokens JWT.
# STORAGE_SECRET → firma la cookie de sesión de NiceGUI.
#
# Son INDEPENDIENTES: si uno se filtra, el otro no debe caer. En producción
# AMBOS deben ser cadenas aleatorias de >=32 caracteres y DISTINTAS entre sí.
# En production, el arranque se BLOQUEA si conservan su valor por defecto.
#
# Genera cada uno con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=cambia-esta-clave-en-produccion-ahora
STORAGE_SECRET=cambia-este-storage-secret-en-produccion

# Minutos de vida del token JWT (1..1440). Default: 480 (jornada de 8 h).
JWT_EXPIRE_MINUTES=480

# -----------------------------------------------------------------------------
# Servidor NiceGUI
# -----------------------------------------------------------------------------
# Host de escucha. 127.0.0.1 = solo local; 0.0.0.0 = expone en la red.
HOST=127.0.0.1
# Puerto (1..65535).
PORT=8080
#
# ─ Despliegue en producción (TLS / reverse proxy) ────────────────────────────
# NiceGUI no termina TLS: en producción la app DEBE servirse tras un reverse
# proxy (nginx/Caddy) que termine HTTPS. Mantén HOST=127.0.0.1 para que solo el
# proxy local alcance la app; NUNCA expongas 0.0.0.0 sin HTTPS (la cookie de
# sesión viajaría en claro). El proxy escucha en 443 y reenvía a este PORT.
# Guía completa: docs/seguridad.md.

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Nivel de log: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
